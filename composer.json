{
    "name": "hydrat/filament-lexi-translatable",
    "description": "Filament support for `omaralalwi/lexi-translate`.",
    "license": "MIT",
    "homepage": "https://github.com/Hydrat-Agency/Filament-Lexi-translatable",
    "support": {
        "issues": "https://github.com/Hydrat-Agency/Filament-Lexi-translatable/issues",
        "source": "https://github.com/Hydrat-Agency/Filament-Lexi-translatable"
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/tgeorgel/lexi-translate.git"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/support": "^4.0|^5.0",
        "illuminate/support": "^12.0|^13.0",
        "omaralalwi/lexi-translate": "dev-master"
    },
    "autoload": {
        "psr-4": {
            "Hydrat\\FilamentLexiTranslate\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hydrat\\FilamentLexiTranslate\\LexiTranslatablePluginServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}